<%
  css_classes = class_names(
    "event-box cursor-pointer p-4 border rounded-lg hover:bg-gray-50 transition-colors",
    "bg-blue-100 border-blue-400" => selected_event == event,
    "bg-white border-gray-200" => selected_event != event
  )
%>

<%= link_to root_path(slug: event.slug), class: "block", data: { turbo_action: :replace } do %>
  <%= tag.div id: dom_id(event), class: css_classes do %>
    <p class="font-medium"><%= event.date %></p>
    <p class="mt-1 text-sm text-gray-600"><%= event.summary %></p>
  <% end %>
<% end %>
