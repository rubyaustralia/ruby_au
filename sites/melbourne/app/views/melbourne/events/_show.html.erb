
<% set_meta_tags Melbourne::Event::OpenGraphMetadata.new(@event).to_meta_tags %>
<% content_for :head do  %>
  <script type="application/ld+json">
    <%= raw JSON.pretty_generate @event.schema.to_h %>
  </script>
<% end %>

<div class="event-detail">
  <h2 class="text-2xl"><%= @event.name %></h2>
  <p><strong>Date:</strong> <%= @event.date if @event.date %></p>
  <p><strong>Venue:</strong> <%= @event.venue.name if @event.venue&.name %></p>
  <p><strong>Summary:</strong> <%= @event.summary if @event.summary %></p>

  <% if @event.respond_to?(:talks) && @event.talks.any? %>
    <hr class="my-4">
    <h3 class="text-xl">Talks</h3>
    <div class="mt-8">
      <% @event.talks.each do |talk| %>
        <article class="p-4 mb-4 rounded-lg border">
          <% if talk.respond_to?(:description) && talk.description %>
            <p><%= talk.description %></p>
          <% end %>
          <% if talk.respond_to?(:speakers) && talk.speakers.any? %>
            <strong>Speakers:</strong>
            <ul class="pl-5 list-disc">
              <% talk.speakers.each do |speaker| %>
                <li>
                  <% if speaker.respond_to?(:name) && speaker.name %>
                    <p><%= speaker.name %></p>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% end %>
        </article>
      <% end %>
    </div>
  <% end %>
</div>


