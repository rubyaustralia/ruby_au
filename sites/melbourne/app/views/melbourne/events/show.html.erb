
<% set_meta_tags Melbourne::Event::OpenGraphMetadata.new(@event).to_meta_tags %>
<% content_for :head do  %>
  <script type="application/ld+json">
    <%= raw JSON.pretty_generate @event.schema.to_h %>
  </script>
<% end %>

<%= turbo_frame_tag "event_show" do %>
  <%= render partial: "melbourne/events/show", locals: { event: @event } %>
<% end %>

