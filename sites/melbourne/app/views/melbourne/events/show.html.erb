<% set_meta_tags Melbourne::Event::OpenGraphMetadata.new(@event).to_meta_tags %>


<div class="container mx-auto">
  <h1></h1>

  <h2 class="text-2xl">Talks</h2>
  <div class="mt-8">
    <% @event.talks.each do |talk| %>
      <article>
        <p>
          <%= talk.description %>
        </p>
        <ul>
          <% talk.speakers.each do |speaker| %>
            <li>
              <p><%= speaker.name %></p>
              <p><%= speaker.contact_details %></p>
            </li>
          <% end %>
        </ul>
      </article>
    <% end %>
  </div>
</div>
