<div class="container mx-auto">
  <% @event.talks.each do |talk| %>
    <article>
      <p>
        <%= talk.description %>
      </p>
      <ul>
        <% talk.speakers.each do |speaker| %>
          <li>
            <p><%= speaker.name %></p>
            <p><%= speaker.contact_details %></p>
          </li>
        <% end %>
      </ul>
    </article>
  <% end %>
</div>
