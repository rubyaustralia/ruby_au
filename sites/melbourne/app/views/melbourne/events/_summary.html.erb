<article class="flex flex-col col-start-3 px-4 py-6">
  <div class="event-detail">
    <h2 class="text-2xl"><%= event.name %></h2>
    <p><strong>Date:</strong> <%= event.date %></p>
    <p><strong>Venue:</strong> <%= event.venue.name  %></p>
    <p><strong>Summary:</strong> <%= event.summary %></p>

      <hr class="my-4">
      <h3 class="text-xl">Talks</h3>
      <div class="mt-8">
        <%= render collection: event.talks, partial: "melbourne/events/talk" %>
      </div>
  </div>
</article>
