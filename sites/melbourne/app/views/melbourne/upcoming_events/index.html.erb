<%= render "layouts/melbourne/navigation" %>
<div class="container mx-auto my-16">
  <div class="flex gap-4 mt-2 mb-1 pl-4">
    <div class="min-w-16 font-bold px-4 py-2 border-b-3 border-b-[#0025CA] text-gray-500" aria-current="page">Upcoming Events</div>
    <%= link_to "Past Events", melbourne_past_events_path, class:"min-w-16 px-4 py-2 cursor-pointer rounded-md text-gray-500 hover:bg-[var(--code-off-white)] hover:text-gray-400" %>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <%= render @events %>
  </div>
</div>
