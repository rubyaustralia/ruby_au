<%= form_with(model: [:melbourne, database_event], class: "w-full max-w-4xl mx-auto") do |form| %>
  <% if database_event.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded-md">
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h2 class="text-sm sm:text-base font-medium text-red-800">
            <%= pluralize(database_event.errors.count, "error") %> prohibited this event from being saved:
          </h2>
          <ul class="mt-2 pl-5 list-disc text-sm text-red-700">
            <% database_event.errors.each do |error| %>
              <li class="mt-1"><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="space-y-6 sm:space-y-8">
    <div class="space-y-1 sm:space-y-2">
      <%= form.label :name, class: "block text-sm sm:text-base font-medium text-gray-700" %>
      <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ruby-red focus:ring focus:ring-ruby-red/20 text-sm sm:text-base" %>
    </div>

    <div class="space-y-1 sm:space-y-2">
      <%= form.label :date, class: "block text-sm sm:text-base font-medium text-gray-700" %>
      <%= form.date_select :date, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ruby-red focus:ring focus:ring-ruby-red/20 text-sm sm:text-base" %>
    </div>

    <div class="space-y-1 sm:space-y-2">
      <%= form.label :start_time, class: "block text-sm sm:text-base font-medium text-gray-700" %>
      <%= form.time_select :start_time, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ruby-red focus:ring focus:ring-ruby-red/20 text-sm sm:text-base" %>
    </div>

    <div class="space-y-1 sm:space-y-2">
      <%= form.label :end_time, class: "block text-sm sm:text-base font-medium text-gray-700" %>
      <%= form.time_select :end_time, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ruby-red focus:ring focus:ring-ruby-red/20 text-sm sm:text-base" %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div class="space-y-1 sm:space-y-2">
        <%= form.label :region, class: "block text-sm sm:text-base font-medium text-gray-700" %>
        <%= form.select :region, ["adelaide", "brisbane", "melbourne", "perth", "sydney"] %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div class="space-y-1 sm:space-y-2">
        <%= form.label :event_type, class: "block text-sm sm:text-base font-medium text-gray-700" %>
        <%= form.select :event_type, ["agm", "conference", "meetup", "rails_girls", "ruby_retreat"] %>
      </div>
    </div>

    <div class="space-y-1 sm:space-y-2">
      <%= form.label :description, class: "block text-sm sm:text-base font-medium text-gray-700" %>
      <div class="mt-1 sm:mt-2 prose-container">
        <%= form.rich_textarea :description %>
      </div>
      <p class="text-xs sm:text-sm text-gray-500 mt-1">Use formatting tools to enhance your content</p>
    </div>

    <div class="space-y-1 sm:space-y-2">
      <%= form.label :slug, class: "block text-sm sm:text-base font-medium text-gray-700" %>
      <%= form.text_field :slug, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ruby-red focus:ring focus:ring-ruby-red/20 text-sm sm:text-base" %>
    </div>

    <div class="space-y-1 sm:space-y-2">
      <%= form.label :venue, class: "block text-sm sm:text-base font-medium text-gray-700" %>
      <%= form.collection_select :venue_id, Venue.order(:name), :id, :name %>
    </div>

    <div class="space-y-1 sm:space-y-2">
      <%= form.label :registration_url, class: "block text-sm sm:text-base font-medium text-gray-700" %>
      <%= form.text_field :registration_url, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-ruby-red focus:ring focus:ring-ruby-red/20 text-sm sm:text-base" %>
    </div>

    <div class="pt-4 sm:pt-6">
      <%= form.submit class: "inline-flex justify-center py-2 px-4 sm:py-3 sm:px-6 border border-transparent shadow-sm text-sm sm:text-base
      font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" %>

    </div>
  </div>
<% end %>
