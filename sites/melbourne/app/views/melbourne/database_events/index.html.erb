<%= render "layouts/melbourne/navigation" %>

<div class="container mx-auto my-16">
  <% if current_meetup_admin? %>
  <div class="my-4 sm:my-5 lg:my-6 px-3 sm:px-4 lg:px-5 bg-white">
      <%= link_to new_melbourne_database_event_path, class: "inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition-colors shadow-sm text-sm sm:text-base" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        New Event
      <% end %>
  </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <%= render @database_events %>
  </div>
</div>
