<%= form_with(model: [:admin, election], class: "space-y-6 sm:space-y-8") do |form| %>
  <% if election.errors.any? %>
    <div id="error_explanation" class="bg-red-50 border-l-4 border-red-500 p-4 sm:p-5 rounded-md mb-6">
      <h3 class="text-red-800 font-medium"><%= pluralize(election.errors.count, "error") %> prohibited this from being saved:</h3>
      <ul class="mt-2 list-disc pl-5 space-y-1 text-red-700">
        <% election.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 items-start">
    <%= form.label :title, class: "block text-sm font-medium text-gray-700 md:text-right md:mt-2" %>
    <div class="md:col-span-2">
      <%= form.text_field :title, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-ruby-red focus:border-ruby-red" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 items-start">
    <%= form.label :vacancies, class: "block text-sm font-medium text-gray-700 md:text-right md:mt-2" %>
    <div class="md:col-span-2">
      <%= form.number_field :vacancies, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-ruby-red focus:border-ruby-red" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 items-start">
    <%= form.label :point_scale, class: "block text-sm font-medium text-gray-700 md:text-right md:mt-2" %>
    <div class="md:col-span-2">
      <%= form.number_field :point_scale, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-ruby-red focus:border-ruby-red" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 items-start">
    <%= form.label :opened_at, class: "block text-sm font-medium text-gray-700 md:text-right md:mt-2" %>
    <div class="md:col-span-2">
      <%= form.datetime_field :opened_at, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-ruby-red focus:border-ruby-red" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 items-start">
    <%= form.label :closed_at, class: "block text-sm font-medium text-gray-700 md:text-right md:mt-2" %>
    <div class="md:col-span-2">
      <%= form.datetime_field :closed_at, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-ruby-red focus:border-ruby-red" %>
    </div>
  </div>

  <div class="md:ml-[calc(100%/3)] pt-5">
    <%= form.submit class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-ruby-red hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-ruby-red transition-colors" %>
  </div>
<% end %>
