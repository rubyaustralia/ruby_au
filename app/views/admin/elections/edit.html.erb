<div class="max-w-xs sm:max-w-xl md:max-w-3xl lg:max-w-4xl mx-auto px-4 sm:px-6 md:px-8 py-8 sm:py-12 md:py-16">
  <div class="space-y-12 sm:space-y-16 md:space-y-20">
    <section>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-6 sm:mb-8">Edit Election</h1>

      <%= render "form", election: @election %>

      <div class="mt-8 flex flex-col sm:flex-row sm:items-center gap-4 border-t border-gray-200 pt-8">
        <%= link_to admin_election_path(@election), class: "group inline-flex items-center justify-center text-gray-700 hover:text-ruby-red transition-colors text-sm sm:text-base" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to election
        <% end %>
      </div>
    </section>
  </div>
</div>
