<%= form_with(model: [:admin, post], class: "space-y-6 sm:space-y-8") do |form| %>
  <% if post.errors.any? %>
    <div id="error_explanation" class="bg-red-50 border-l-4 border-red-500 p-4 sm:p-5 rounded-md mb-6">
      <h3 class="text-red-800 font-medium"><%= pluralize(post.errors.count, "error") %> prohibited this from being saved:</h3>
      <ul class="mt-2 list-disc pl-5 space-y-1 text-red-700">
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 items-start">
    <%= form.label :title, class: "block text-sm font-medium text-gray-700 md:text-right md:mt-2" %>
    <div class="md:col-span-2">
      <%= form.text_field :title, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-ruby-red focus:border-ruby-red" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 items-start">
    <%= form.label :content, class: "block text-sm font-medium text-gray-700 md:text-right md:mt-2" %>
    <div class="md:col-span-2 prose-container">
      <%= form.rich_textarea :content %>
      <p class="mt-1 text-sm text-gray-500">
        Use formatting tools to enhance your content
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 items-start">
    <%= form.label :category, class: "block text-sm font-medium text-gray-700 md:text-right md:mt-2" %>
    <div class="md:col-span-2">
      <%= form.select :category,
                      Post.categories.keys.map{ |key| [key.humanize, key] },
                      {},
                      { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-ruby-red focus:border-ruby-red" } %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 items-start">
    <%= form.label :status, class: "block text-sm font-medium text-gray-700 md:text-right md:mt-2" %>
    <div class="md:col-span-2">
      <%= form.select :status,
                      Post.statuses.keys.map{ |key| [key.humanize, key] },
                      {},
                      { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-ruby-red focus:border-ruby-red" } %>
    </div>
  </div>

  <% unless @post.published_at %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 items-start">
      <%= form.label :publish_scheduled_at, class: "block text-sm font-medium text-gray-700 md:text-right md:mt-2" %>
      <div class="md:col-span-2">
        <%= form.datetime_field :publish_scheduled_at,
                                disabled: @post.publish_scheduled_at?,
                                class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-ruby-red focus:border-ruby-red #{'opacity-60 cursor-not-allowed' if @post.publish_scheduled_at?}" %>
        <% if @post.publish_scheduled_at? %>
          <p class="mt-1 text-sm text-gray-500 italic">Scheduled date cannot be modified. Archive or delete this post first, then create a new one.</p>
        <% else %>
          <p class="mt-1 text-sm text-gray-500">When should this post be published?</p>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="md:ml-[calc(100%/3)] pt-5">
    <%= form.submit class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-ruby-red hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-ruby-red transition-colors" %>
  </div>
<% end %>
