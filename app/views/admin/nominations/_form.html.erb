<%= form_with(model: [:admin, :election, nomination], class: "w-full mx-auto") do |form| %>
  <% if nomination.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded-md">
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h2 class="text-sm sm:text-base font-medium text-red-800">
            <%= pluralize(nomination.errors.count, "error") %> prohibited this nomination from being saved:
          </h2>
          <ul class="mt-2 pl-5 list-disc text-sm text-red-700">
            <% nomination.errors.each do |error| %>
              <li class="mt-1"><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="space-y-6 sm:space-y-8">
    <div class="space-y-1 sm:space-y-2" data-controller="autocomplete" data-autocomplete-url-value="<%= search_admin_users_path %>">
      <%= form.label :member_email_address, "Nominated Member (Search by name)", class: "block text-sm sm:text-base font-medium text-gray-700" %>
      <div class="relative">
        <%= text_field_tag :member_name_lookup, nomination.nominee&.full_name,
                          placeholder: "Start typing a name...",
                          class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-ruby-red focus:border-ruby-red sm:text-sm",
                          data: {
                            autocomplete_target: "input",
                            action: "input->autocomplete#onInput keydown->autocomplete#onKeydown focus->autocomplete#onInput"
                          } %>
        <%= form.hidden_field :member_email_address, data: { autocomplete_target: "hiddenInput" } %>
        <div data-autocomplete-target="results" class="absolute z-10 w-full bg-white border border-gray-300 rounded-md mt-1 shadow-lg max-h-60 overflow-y-auto hidden"></div>
      </div>
    </div>

    <div class="space-y-1 sm:space-y-2" data-controller="autocomplete" data-autocomplete-url-value="<%= search_admin_users_path %>">
      <%= form.label :nominating_member_email_address, "Nominating Member (Search by name)", class: "block text-sm sm:text-base font-medium text-gray-700" %>
      <div class="relative">
        <%= text_field_tag :nominating_member_name_lookup, nomination.nominated_by&.full_name,
                          placeholder: "Start typing a name...",
                          class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-ruby-red focus:border-ruby-red sm:text-sm",
                          data: {
                            autocomplete_target: "input",
                            action: "input->autocomplete#onInput keydown->autocomplete#onKeydown focus->autocomplete#onInput"
                          } %>
        <%= form.hidden_field :nominating_member_email_address, value: nomination.nominated_by&.email, data: { autocomplete_target: "hiddenInput" } %>
        <div data-autocomplete-target="results" class="absolute z-10 w-full bg-white border border-gray-300 rounded-md mt-1 shadow-lg max-h-60 overflow-y-auto hidden"></div>
      </div>
    </div>

    <div class="pt-4 sm:pt-6">
      <%= form.submit class: "inline-flex justify-center py-2 px-4 sm:py-3 sm:px-6 border border-transparent shadow-sm text-sm sm:text-base font-medium rounded-md text-white bg-ruby-red hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-ruby-red transition-colors" %>
    </div>
  </div>
<% end %>
