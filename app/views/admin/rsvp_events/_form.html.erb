<%= form_with model: [:admin, event],
            class: "bg-white rounded-lg shadow-sm border border-gray-200 grid grid-cols-1 gap-y-6 p-4 align-start" do |form| %>

<% if event.errors.any? %>
  <div class="rounded-md bg-red-50 p-4 mb-6">
    <div class="flex items-start">
      <div class="flex-shrink-0">
        <i data-lucide="alert-circle" class="h-5 w-5 text-red-400" aria-hidden="true"></i>
      </div>
      <div class="ml-3">
        <h3 class="text-sm font-medium text-red-800">
          <%= pluralize(event.errors.count, "error") %> prohibited this event from being created:
        </h3>
        <div class="mt-2 text-sm text-red-700">
          <ul class="list-disc pl-5 space-y-1">
            <% event.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  </div>
<% end %>

<div class="grid grid-rows-2 gap-y-6">
  <%= form.label :title, class: "text-lg font-medium" %>
  <%= form.text_field :title, required: true, placeholder: "New Awesome Event", class: "w-full px-1 py-0.5 rounded-sm border-gray-300 shadow-sm focus:border-ruby-red focus:ring focus:ring-ruby-red focus:ring-opacity-50 text-sm sm:text-base" %>
</div>

<div class="grid grid-rows-2 gap-y-6">
  <%= form.label :happens_at, class: "text-lg font-medium" %>
  <div class="flex md:flex-row md:flex-wrap items-center justify-start gap-x-2 overflow-hidden py-1">
    <%= form.datetime_select :happens_at,
                            { selected: Time.current, start_year: Time.current.year },
                            {
                              required: true,
                              class: "px-1 py-0.5 rounded-sm border-gray-300 shadow-sm focus:border-ruby-red focus:ring focus:ring-ruby-red focus:ring-opacity-50 text-sm sm:text-base" } %>

    <%= form.time_zone_select :time_zone,
                              ActiveSupport::TimeZone.country_zones("AU"),
                              { required: true, default: "Sydney" },
                              { class: "px-1 py-0.5 rounded-sm border-gray-300 shadow-sm focus:border-ruby-red focus:ring focus:ring-ruby-red focus:ring-opacity-50 text-sm sm:text-base" } %>
  </div>
</div>

<div class="flex flex-row gap-x-4 items-center justify-between py-0.5">
  <%= form.submit "Create Event", class: "py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-ruby-red hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-ruby-red transition-colors" %>

  <%= link_to "Cancel", admin_rsvp_events_path,
              class: "py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-ruby-red transition-colors" %>
</div>
<% end %>
