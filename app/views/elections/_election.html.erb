<div id="<%= dom_id election %>" class="w-full">
  <header class="text-center mb-6 sm:mb-8 md:mb-10 pb-4 sm:pb-6 border-b border-gray-200">
    <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-3 sm:mb-4">
      Election for <%= election.title %>
    </h1>
    <div class="text-sm sm:text-base text-gray-600">
      <% if election.open? %>
        Closes in <%= time_ago_in_words(election.closed_at) %>
      <% else %>
        Closed at <%= I18n.l(election.closed_at) %>
      <% end %>
    </div>
  </header>

  <% if election.voting_completed_for?(current_user) %>
    <div class="flex justify-center">
      <p class="text-sm bg-red-100 p-4 w-fit rounded-md mb-10">You have already voted in this election.</p>
    </div>
    <%= render "ballot", election: election %>
  <% else %>
    <div class="flex justify-center">
      <p class="text-sm bg-blue-100 p-4 w-fit rounded-md mb-10">Give each nominee a score between <%= election.minimum_score %> and <%= election.maximum_score %>.</p>
    </div>
    <%= render "form", election: election, ballot: ballot %>
  <% end %>
</div>
